# EmailJS (https://www.emailjs.com/) — used by the booking wizard in App.jsx
#
# 1. Copy this file to `.env` and set values from EmailJS → Account / Email Services / Templates.
# 2. Restart the dev server after changing env vars.
# 3. Netlify: Site configuration → Environment variables → add all three (same names, no Vite prefix change).

VITE_EMAILJS_SERVICE_ID=service_nz1hmff
VITE_EMAILJS_TEMPLATE_ID=template_nnjeipk
VITE_EMAILJS_PUBLIC_KEY=bwsFY86eNZ5xIqx8M
